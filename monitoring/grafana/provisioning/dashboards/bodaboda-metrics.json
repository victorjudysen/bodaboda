{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["bodaboda", "users"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "BodaBoda Digital – User Metrics",
  "uid": "bodaboda-users",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Registered Users",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "bodaboda_registered_users", "refId": "A", "instant": true }
      ]
    },
    {
      "id": 2,
      "title": "Active (Available) Riders",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "bodaboda_active_riders", "refId": "A", "instant": true }
      ]
    },
    {
      "id": 3,
      "title": "Total Trips",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "bodaboda_total_trips", "refId": "A", "instant": true }
      ]
    },
    {
      "id": 4,
      "title": "Pending Trips",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "yellow", "mode": "fixed" },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "bodaboda_trips_by_status{status=\"pending\"}", "refId": "A", "instant": true }
      ]
    },
    {
      "id": 5,
      "title": "Ride Requests Rate (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "options": {
        "legend": { "calcs": ["mean","max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(bodaboda_ride_requests_total[2m]) * 60",
          "legendFormat": "Ride Requests / min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "User Registrations Rate (per minute)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "options": {
        "legend": { "calcs": ["mean","max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(bodaboda_user_registrations_total[2m]) * 60",
          "legendFormat": "Registrations / min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Trips by Status",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "options": {
        "displayLabels": ["percent", "name"],
        "legend": { "displayMode": "list", "placement": "right", "showLegend": true },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "bodaboda_trips_by_status",
          "legendFormat": "{{status}}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 8,
      "title": "Login Attempts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(bodaboda_login_attempts_total[5m])",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    }
  ]
}
